{
  "name": "prairieclassroom-os",
  "version": "0.0.1",
  "private": true,
  "description": "Gemma-4-native, local-first classroom complexity copilot for Alberta K-6",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "evals"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:python": "cd services/inference && python -m pytest tests/ -v",
    "eval": "tsx evals/runner.ts",
    "rebuild:memory": "npm rebuild better-sqlite3 --workspace @prairie/memory",
    "provision:vertex-endpoints": "node scripts/provision-vertex-endpoints.mjs",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:browser": "node scripts/smoke-browser.mjs",
    "smoke": "npm run smoke:api && npm run smoke:browser",
    "release:gate": "node scripts/release-gate.mjs --inference-mode mock",
    "release:gate:real": "node scripts/release-gate.mjs --inference-mode api --update-baseline"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "eslint": "^10.2.0",
    "playwright": "^1.54.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "zod": "^4.3.6"
  }
}
