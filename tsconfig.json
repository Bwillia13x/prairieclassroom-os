{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@prairie/shared/*": ["packages/shared/*"]
    }
  },
  "include": ["packages/**/*.ts", "services/**/*.ts", "evals/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
