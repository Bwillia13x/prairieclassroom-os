{
  "name": "@prairie/marketing-video",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "still": "remotion still src/index.ts PrairieClassroomMarketing --frame=420 --output=../../qa/demo-script/videos/remotion-marketing-preview.png --timeout=120000",
    "render": "remotion render src/index.ts PrairieClassroomMarketing ../../qa/demo-script/videos/remotion-marketing-demo.mp4 --codec=h264 --audio-codec=aac --pixel-format=yuv420p --timeout=120000"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.448",
    "remotion": "^4.0.448",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.7.0"
  }
}
