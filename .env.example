# PrairieClassroom OS — Environment Variables
# Copy this file to .env and fill in values for your environment.

# Orchestrator
PORT=3100
INFERENCE_URL=http://127.0.0.1:3200
CORS_ORIGIN=http://localhost:5173

# Eval runner (optional — defaults to http://localhost:3100)
# API_BASE=http://localhost:3100

# Vertex AI (required for --mode api only)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
