# PrairieClassroom OS — Environment Variables
# Copy this file to .env and fill in values for your environment.

# Orchestrator
PORT=3100
INFERENCE_URL=http://127.0.0.1:3200
CORS_ORIGIN=http://localhost:5173

# Web UI (optional — only needed when not proxying through Vite)
# VITE_API_URL=http://localhost:3100/api

# Eval runner (optional — defaults to http://localhost:3100)
# API_BASE=http://localhost:3100

# Optional zero-cost proof fixture overrides
# PRAIRIE_DATA_DIR=/abs/path/to/evals/fixtures/classrooms
# PRAIRIE_MEMORY_DIR=/abs/path/to/evals/fixtures/memory

# Python interpreter path (optional — defaults to system python3)
# PRAIRIE_PYTHON=python3

# Optional local prompt/body debug logging (disabled by default)
# PRAIRIE_DEBUG_PROMPTS=false

# Hosted Gemini runs are disabled by default; enable only for intentional demo/eval runs.
PRAIRIE_ENABLE_GEMINI_RUNS=false
# PRAIRIE_GEMINI_API_KEY=
# PRAIRIE_GEMINI_MODEL_ID_LIVE=google/gemma-4-4b-it
# PRAIRIE_GEMINI_MODEL_ID_PLANNING=google/gemma-4-27b-it

# Cost guard (required for any cloud-billed Vertex provisioning or inference)
PRAIRIE_ALLOW_PAID_SERVICES=false

# Vertex AI (required for --mode api only)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# PRAIRIE_VERTEX_BACKEND=vertex
# PRAIRIE_VERTEX_ENDPOINT_LIVE=projects/your-project/locations/us-central1/endpoints/your-live-endpoint
# PRAIRIE_VERTEX_ENDPOINT_PLANNING=projects/your-project/locations/us-central1/endpoints/your-planning-endpoint
