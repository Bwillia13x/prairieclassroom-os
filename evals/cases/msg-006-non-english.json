    "student_refs": ["Ari"],
    "message_type": "praise",
    "target_language": "Spanish",
    "context": "Ari made great progress in reading this week. Participated actively in group discussion."
  },
  "expected": {
    "required_message_keys": ["draft_id", "classroom_id", "student_refs", "message_type", "target_language", "plain_language_text", "teacher_approved", "schema_version"],
