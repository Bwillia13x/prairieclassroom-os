{
  "id": "msg-lang-ar-routine",
  "category": "differentiation_quality",
  "description": "Family message routine_update with target_language=Arabic returns a valid draft for an Arabic-speaking family",
  "prompt_class": "draft_family_message",
  "input": {
    "classroom_id": "alpha-grade4",
    "student_refs": ["Ari"],
    "message_type": "routine_update",
    "target_language": "Arabic",
    "context": "Ari completed the spelling practice this week and used the sentence starters independently on two writing tasks."
  },
  "expected": {
    "required_message_keys": ["draft_id", "classroom_id", "student_refs", "message_type", "target_language", "plain_language_text", "teacher_approved", "schema_version"],
    "schema_version": "0.1.0",
    "must_contain": ["Ari"],
    "must_not_contain": ["diagnosis", "clinical", "disorder", "deficit"]
  }
}
